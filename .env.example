# PulseGate Environment Example

#

# This file documents the environment variables used by PulseGate.

# Copy this file to .env when environment-based configuration is needed.

#

# Note:

# Sprint 0 currently runs services directly with npm scripts.

# Environment variables can be set later when Docker Compose or deployment is added.

# ------------------------------------------------------------

# API Gateway

# ------------------------------------------------------------

# Default local API Gateway port

PORT=3000

# Default local host

HOST=0.0.0.0

# Product Service URL used by API Gateway

PRODUCT_SERVICE_URL=http://127.0.0.1:3001

# Timeout for API Gateway requests to downstream services, in milliseconds

DOWNSTREAM_REQUEST_TIMEOUT_MS=3000

# Header name used by API Gateway for API key authentication

API_KEY_HEADER=x-api-key

# Comma-separated API keys allowed by API Gateway for local development

API_KEYS=dev-api-key

# JWT secret used by API Gateway for local development

JWT_SECRET=local-dev-jwt-secret-change-me

# JWT issuer used when validating tokens

JWT_ISSUER=pulsegate-api-gateway

# JWT audience used when validating tokens

JWT_AUDIENCE=pulsegate-clients

# JWT expiration time in seconds

JWT_EXPIRES_IN_SECONDS=900

# ------------------------------------------------------------

# Product Service

# ------------------------------------------------------------

# When running Product Service separately, use:

# PORT=3001

# HOST=0.0.0.0

# ------------------------------------------------------------

# Future Variables

# ------------------------------------------------------------

# PostgreSQL

# DATABASE_URL=postgresql://user:password@localhost:5432/pulsegate

# Redis

# REDIS_URL=redis://localhost:6379

# Kafka

# KAFKA_BROKERS=localhost:9092

# RabbitMQ

# RABBITMQ_URL=amqp://localhost:5672

# JWT

# API Key

# API_KEY_HEADER=x-api-key

# Observability

# OTEL_SERVICE_NAME=pulsegate

# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
