{
  "name": "api-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "postbuild": "node -e \"require('node:fs').cpSync('src/generated/prisma', 'dist/generated/prisma', { recursive: true })\"",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "analytics:rollup:backfill": "tsx src/analytics/analytics-rollup-backfill.command.ts",
    "analytics:rollup:schedule-preview": "tsx src/analytics/analytics-rollup-schedule-preview.command.ts",
    "analytics:rollup:scheduler-preview": "tsx src/analytics/analytics-rollup-scheduler-preview.command.ts",
    "analytics:retention:dry-run": "tsx src/analytics/analytics-retention-dry-run.command.ts",
    "analytics:retention:execution-preview": "tsx src/analytics/analytics-retention-execution-preview.command.ts",
    "analytics:retention:operator-preview": "tsx src/analytics/analytics-retention-operator-preview.command.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/core": "2.9.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@prisma/client": "^6.19.3",
    "fastify": "^5.8.5",
    "jose": "^6.2.3",
    "prom-client": "^15.1.3",
    "redis": "^5.10.0"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  }
}
