generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GatewayRouteMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

enum ApiConsumerStatus {
  ACTIVE
  DISABLED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

enum UsagePlanQuotaWindow {
  DAILY
  MONTHLY
}

model GatewayRoute {
  id            String             @id @default(cuid())
  serviceName   String             @map("service_name")
  gatewayPath   String             @map("gateway_path")
  downstreamUrl String             @map("downstream_url")
  method        GatewayRouteMethod
  enabled       Boolean            @default(true)
  priority      Int                @default(100)

  requireApiKey Boolean @default(false) @map("require_api_key")
  requireJwt    Boolean @default(false) @map("require_jwt")

  timeoutEnabled Boolean @default(true) @map("timeout_enabled")
  timeoutMs      Int     @default(3000) @map("timeout_ms")

  cacheEnabled    Boolean @default(false) @map("cache_enabled")
  cacheTtlSeconds Int     @default(30) @map("cache_ttl_seconds")

  rateLimitEnabled  Boolean @default(false) @map("rate_limit_enabled")
  rateLimitLimit    Int     @default(100) @map("rate_limit_limit")
  rateLimitWindowMs Int     @default(60000) @map("rate_limit_window_ms")

  requestTransformEnabled Boolean @default(false) @map("request_transform_enabled")
  requestAddHeaders       Json?   @map("request_add_headers")
  requestRemoveHeaders    Json?   @map("request_remove_headers")

  responseTransformEnabled Boolean @default(false) @map("response_transform_enabled")
  responseAddHeaders       Json?   @map("response_add_headers")
  responseRemoveHeaders    Json?   @map("response_remove_headers")

  retryEnabled    Boolean @default(false) @map("retry_enabled")
  retryAttempts   Int     @default(0) @map("retry_attempts")
  retryOnStatuses Json    @map("retry_on_statuses")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([enabled, priority], name: "gateway_routes_enabled_priority_idx")
  @@index([deletedAt], name: "gateway_routes_deleted_at_idx")
  @@index([enabled, deletedAt, priority], name: "gateway_routes_enabled_deleted_at_priority_idx")
  @@map("gateway_routes")
}

model ApiConsumer {
  id          String            @id @default(cuid())
  name        String
  description String?
  status      ApiConsumerStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")

  apiKeys        ApiKey[]
  apiUsageEvents ApiUsageEvent[]

  @@index([status], name: "api_consumers_status_idx")
  @@index([createdAt], name: "api_consumers_created_at_idx")
  @@map("api_consumers")
}

model ApiKey {
  id         String      @id @default(cuid())
  consumerId String      @map("consumer_id")
  consumer   ApiConsumer @relation(fields: [consumerId], references: [id], onDelete: Restrict)

  name      String
  keyPrefix String       @map("key_prefix")
  keyHash   String       @unique @map("key_hash")
  status    ApiKeyStatus @default(ACTIVE)

  expiresAt  DateTime? @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy String?   @map("created_by")
  revokedAt DateTime? @map("revoked_at")
  revokedBy String?   @map("revoked_by")

  usagePlanId String?    @map("usage_plan_id")
  usagePlan   UsagePlan? @relation(fields: [usagePlanId], references: [id], onDelete: SetNull)

  usageEvents ApiUsageEvent[]

  @@index([consumerId], name: "api_keys_consumer_id_idx")
  @@index([status], name: "api_keys_status_idx")
  @@index([keyPrefix], name: "api_keys_key_prefix_idx")
  @@index([expiresAt], name: "api_keys_expires_at_idx")
  @@index([usagePlanId], name: "api_keys_usage_plan_id_idx")
  @@map("api_keys")
}

model UsagePlan {
  id          String               @id @default(cuid())
  name        String               @unique
  description String?
  quotaLimit  Int                  @map("quota_limit")
  quotaWindow UsagePlanQuotaWindow @map("quota_window")
  enabled     Boolean              @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy String? @map("created_by")
  updatedBy String? @map("updated_by")

  apiKeys ApiKey[]

  @@index([enabled], name: "usage_plans_enabled_idx")
  @@index([quotaWindow], name: "usage_plans_quota_window_idx")
  @@index([createdAt], name: "usage_plans_created_at_idx")
  @@map("usage_plans")
}

model ApiUsageEvent {
  id String @id @default(cuid())

  requestId String @map("request_id")

  routePath   String             @map("route_path")
  routeMethod GatewayRouteMethod @map("route_method")

  statusCode Int @map("status_code")
  durationMs Int @map("duration_ms")

  cacheStatus      String? @map("cache_status")
  apiKeyAuthSource String? @map("api_key_auth_source")

  apiKeyId String? @map("api_key_id")
  apiKey   ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  consumerId String?      @map("consumer_id")
  consumer   ApiConsumer? @relation(fields: [consumerId], references: [id], onDelete: SetNull)

  occurredAt DateTime @default(now()) @map("occurred_at")

  @@index([occurredAt], name: "api_usage_events_occurred_at_idx")
  @@index([consumerId, occurredAt], name: "api_usage_events_consumer_id_occurred_at_idx")
  @@index([apiKeyId, occurredAt], name: "api_usage_events_api_key_id_occurred_at_idx")
  @@index([routeMethod, routePath, occurredAt], name: "api_usage_events_route_method_path_occurred_at_idx")
  @@index([statusCode], name: "api_usage_events_status_code_idx")
  @@index([apiKeyAuthSource], name: "api_usage_events_auth_source_idx")
  @@map("api_usage_events")
}
