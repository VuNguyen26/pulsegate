{
  "name": "pulsegate",
  "version": "0.1.0",
  "private": "true",
  "description": "PulseGate - High-Traffic API Gateway & Observability Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
  "dev:gateway": "npm run dev -w apps/api-gateway",
  "dev:product": "npm run dev -w apps/product-service",
  "dev:dashboard": "npm run dev -w apps/admin-dashboard",
  "build": "npm run build --workspaces",
  "typecheck": "npm run typecheck --workspaces",
  "test": "npm run test --workspaces --if-present",
  "test:k6:smoke": "docker compose --profile tools run --rm k6",
  "validate:release": "node scripts/release-readiness.mjs",
  "demo:runtime": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/demo-runtime.ps1"
  },
  "keywords": [
    "api-gateway",
    "observability",
    "typescript",
    "nodejs",
    "microservices"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
