{
  "name": "pulsegate",
  "version": "0.1.0",
  "private": "true",
  "description": "PulseGate - High-Traffic API Gateway & Observability Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:gateway": "npm run dev -w apps/api-gateway",
    "dev:product": "npm run dev -w apps/product-service",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "keywords": [
    "api-gateway",
    "observability",
    "typescript",
    "nodejs",
    "microservices"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
